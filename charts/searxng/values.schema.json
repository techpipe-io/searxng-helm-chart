{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "nameOverride": {
      "type": "string"
    },
    "fullnameOverride": {
      "type": "string"
    },
    "image": {
      "type": "object",
      "properties": {
        "repository": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        },
        "pullPolicy": {
          "type": "string"
        },
        "pullSecrets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "service": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      },
      "additionalProperties": true
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "hosts": {
          "type": "array"
        },
        "tls": {
          "type": "array"
        }
      },
      "additionalProperties": true
    },
    "gateway": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "parentRefs": {
          "type": "array"
        },
        "hostnames": {
          "type": "array"
        }
      },
      "additionalProperties": true
    },
    "env": {
      "type": "object",
      "properties": {
        "forceOwnership": {
          "type": "boolean"
        },
        "values": {
          "type": "object"
        },
        "secretValues": {
          "type": "object"
        },
        "existingSecrets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "existingConfigMaps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "secret": {
      "type": "object",
      "properties": {
        "create": {
          "type": "boolean"
        },
        "existingSecret": {
          "type": "string"
        },
        "existingSecretKey": {
          "type": "string"
        },
        "value": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "config": {
      "type": "object",
      "properties": {
        "useDefaultSettings": {
          "type": "boolean"
        },
        "settings": {
          "type": "object"
        },
        "files": {
          "type": "object"
        },
        "secretFiles": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "persistence": {
      "type": "object",
      "additionalProperties": true
    },
    "valkey": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "externalUrl": {
          "type": "string"
        },
        "auth": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "password": {
              "type": "string"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "resources": {
      "type": "object",
      "additionalProperties": true
    },
    "probes": {
      "type": "object",
      "additionalProperties": true
    },
    "extraVolumes": {
      "type": "array"
    },
    "extraVolumeMounts": {
      "type": "array"
    },
    "caCertificates": {
      "type": "object",
      "additionalProperties": true
    },
    "testConnection": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
